generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  username         String   @unique
  passwordHash     String
  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  mustChangePassword Boolean @default(true) // force a password change on first login
  isActive         Boolean  @default(true)  // admin can deactivate without deleting
  role             String   @default("USER") // ADMIN, USER
  defaultUsdRate   Float    @default(25400)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  name        String
  type        String   // INVOICE (Income), COST (Expense)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]
}

model Transaction {
  id            String   @id @default(cuid())
  date          DateTime
  type          String   // INCOME, EXPENSE
  currency      String   @default("VND") // VND or USD
  exchangeRate  Float    @default(1.0)
  amount        Float
  description   String?
  invoiceNumber String?
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  invoiceId     String?   @unique // set when this income row is an invoice payment
  invoice       Invoice?  @relation(fields: [invoiceId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  attachments   Attachment[]
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects  Project[]
  invoices  Invoice[]
}

model Project {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("ACTIVE") // ACTIVE, DONE, ARCHIVED
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
  invoices     Invoice[]
}

model Invoice {
  id           String    @id @default(cuid())
  number       String    @unique
  clientId     String?
  client       Client?   @relation(fields: [clientId], references: [id])
  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id])
  issueDate    DateTime
  dueDate      DateTime
  currency     String    @default("VND")
  exchangeRate Float     @default(1.0)
  amount       Float
  status       String    @default("DRAFT") // DRAFT, SENT, PAID, VOID
  paidDate     DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  transaction  Transaction? // income row created when marked paid
}

model Attachment {
  id            String   @id @default(cuid())
  filePath      String
  fileType      String
  fileName      String
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model BankBalance {
  id          String   @id @default(cuid())
  balance     Float
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UnitRate {
  id          String   @id @default(cuid())
  description String
  rate        Float
  unit        String   // hours, project, manday
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
